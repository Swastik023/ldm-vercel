/**
 * PUT /student/profile - Update student's own profile (limited fields)
 */
$app->put('/student/profile', function (Request $request, Response $response) {
    $user = $request->getAttribute('user');
    $studentId = $user->user_id;
    $data = $request->getParsedBody();
    $db = getDB();
    
    // Only allow updating specific fields
    $allowedFields = [
        'phone1', 'phone1Type', 'phone2',
        'address1', 'address1District',
        'emergency1Name', 'emergency1Number1', 'emergency1Relationship'
    ];
    
    $updates = [];
    $params = ['id' => $studentId];
    
    foreach ($allowedFields as $field) {
        if (isset($data[$field])) {
            $updates[] = "$field = :$field";
            $params[$field] = $data[$field];
        }
    }
    
    if (empty($updates)) {
        return ApiResponse::error($response, 'No valid fields to update', 400);
    }
    
    try {
        $sql = "UPDATE gibbonPerson SET " . implode(', ', $updates) . " WHERE gibbonPersonID = :id";
        $stmt = $db->prepare($sql);
        $stmt->execute($params);
        
        AuditLogger::log('update_profile', 'student', $studentId, null, $data, $user);
        
        return ApiResponse::success($response, ['message' => 'Profile updated successfully']);
        
    } catch (PDOException $e) {
        return ApiResponse::serverError($response, 'Database error: ' . $e->getMessage());
    }
})->add(RoleMiddleware::requireRole(['student', 'admin']))->add($authMiddleware);

