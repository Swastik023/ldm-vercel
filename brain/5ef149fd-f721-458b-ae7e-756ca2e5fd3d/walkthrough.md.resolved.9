/**
 * POST /attendance/mark
 * Mark attendance for students
 * 
 * Expected payload:
 * {
 *   "form_group_id": "00001",  // optional, for form group attendance
 *   "class_id": "00000001",    // optional, for class attendance
 *   "date": "2026-02-08",
 *   "records": [
 *     {"student_id": "0000000002", "code": "001", "comment": ""},
 *     {"student_id": "0000000003", "code": "004", "comment": "Sick"}
 *   ]
 * }
 */
$app->post('/attendance/mark', function (Request $request, Response $response) {
    $user = $request->getAttribute('user');
    $data = $request->getParsedBody();

    // Validate required fields
    if (empty($data['date']) || empty($data['records']) || !is_array($data['records'])) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Missing required fields: date and records array'
        ]));
        return $response->withStatus(400);
    }

    // Validate date format
    $date = $data['date'];
    if (!preg_match('/^\d{4}-\d{2}-\d{2}$/', $date)) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Invalid date format. Use YYYY-MM-DD'
        ]));
        return $response->withStatus(400);
    }

    // Determine context
    $context = 'Person';
    $formGroupId = $data['form_group_id'] ?? null;
    $classId = $data['class_id'] ?? null;

    if ($formGroupId) {
        $context = 'Form Group';
    } elseif ($classId) {
        $context = 'Class';
    }

    try {
        $db = getDB();
        $savedCount = 0;
        $errors = [];

        foreach ($data['records'] as $record) {
            $studentId = $record['student_id'] ?? null;
            $codeId = $record['code'] ?? '001'; // Default to Present
            $comment = $record['comment'] ?? '';

            if (!$studentId) {
                $errors[] = 'Missing student_id in record';
                continue;
            }

            // Get attendance code details
            $codeStmt = $db->prepare("SELECT direction, name FROM gibbonAttendanceCode WHERE gibbonAttendanceCodeID = :codeId AND active = 'Y'");
            $codeStmt->execute(['codeId' => $codeId]);
            $codeInfo = $codeStmt->fetch();

            if (!$codeInfo) {
                $errors[] = "Invalid attendance code: $codeId";
                continue;
            }

            // Check if record exists for this student/date/context
            $checkSql = "
                SELECT gibbonAttendanceLogPersonID 
                FROM gibbonAttendanceLogPerson 
                WHERE gibbonPersonID = :studentId 
                AND date = :date 
                AND context = :context
            ";
            $checkParams = [
                'studentId' => $studentId,
                'date' => $date,
                'context' => $context
            ];

            if ($formGroupId) {
                $checkSql .= " AND gibbonFormGroupID = :formGroupId";
                $checkParams['formGroupId'] = $formGroupId;
            }
            if ($classId) {
                $checkSql .= " AND gibbonCourseClassID = :classId";
                $checkParams['classId'] = $classId;
            }

            $checkStmt = $db->prepare($checkSql);
            $checkStmt->execute($checkParams);
            $existing = $checkStmt->fetch();

            if ($existing) {
                // Update existing record
                $updateStmt = $db->prepare("
                    UPDATE gibbonAttendanceLogPerson 
                    SET gibbonAttendanceCodeID = :codeId,
                        direction = :direction,
                        type = :type,
                        comment = :comment,
                        gibbonPersonIDTaker = :takerId,
                        timestampTaken = NOW()
                    WHERE gibbonAttendanceLogPersonID = :logId
                ");
                $updateStmt->execute([
                    'codeId' => $codeId,
                    'direction' => $codeInfo['direction'],
                    'type' => $codeInfo['name'],
                    'comment' => $comment,
                    'takerId' => $user->user_id,
                    'logId' => $existing['gibbonAttendanceLogPersonID']
                ]);
            } else {
                // Insert new record
                $insertStmt = $db->prepare("
                    INSERT INTO gibbonAttendanceLogPerson 
                    (gibbonAttendanceCodeID, gibbonPersonID, direction, type, reason, context, 
                     comment, date, gibbonPersonIDTaker, gibbonFormGroupID, gibbonCourseClassID, timestampTaken)
                    VALUES 
                    (:codeId, :studentId, :direction, :type, '', :context, 
                     :comment, :date, :takerId, :formGroupId, :classId, NOW())
                ");
                $insertStmt->execute([
                    'codeId' => $codeId,
                    'studentId' => $studentId,
                    'direction' => $codeInfo['direction'],
                    'type' => $codeInfo['name'],
                    'context' => $context,
                    'comment' => $comment,
                    'date' => $date,
                    'takerId' => $user->user_id,
                    'formGroupId' => $formGroupId,
                    'classId' => $classId
                ]);
            }
            $savedCount++;
        }

        $response->getBody()->write(json_encode([
            'success' => true,
            'message' => "Attendance marked successfully",
            'records_saved' => $savedCount,
            'errors' => $errors
        ]));

        return $response->withStatus(200);

    } catch (PDOException $e) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Database error: ' . $e->getMessage()
        ]));
        return $response->withStatus(500);
    }
})->add(RoleMiddleware::teacherOrAdmin())->add($authMiddleware);

/**
 * GET /attendance
 * Get attendance records for a class/form group on a date
 */
$app->get('/attendance', function (Request $request, Response $response) {
    $params = $request->getQueryParams();
    $date = $params['date'] ?? date('Y-m-d');
    $formGroupId = $params['form_group_id'] ?? null;
    $classId = $params['class_id'] ?? null;

    if (!$formGroupId && !$classId) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Either form_group_id or class_id is required'
        ]));
        return $response->withStatus(400);
    }

    try {
        $db = getDB();

        // Get students in the group/class with their attendance status
        if ($formGroupId) {
            $stmt = $db->prepare("
                SELECT 
                    p.gibbonPersonID as student_id,
                    CONCAT(p.preferredName, ' ', p.surname) as name,
                    alp.gibbonAttendanceCodeID as code,
                    ac.name as status,
                    ac.nameShort as status_short,
                    alp.comment,
                    alp.timestampTaken
                FROM gibbonPerson p
                JOIN gibbonStudentEnrolment se ON p.gibbonPersonID = se.gibbonPersonID
                LEFT JOIN gibbonAttendanceLogPerson alp ON p.gibbonPersonID = alp.gibbonPersonID 
                    AND alp.date = :date AND alp.context = 'Form Group'
                LEFT JOIN gibbonAttendanceCode ac ON alp.gibbonAttendanceCodeID = ac.gibbonAttendanceCodeID
                WHERE se.gibbonFormGroupID = :formGroupId
                AND p.status = 'Full'
                ORDER BY p.surname, p.preferredName
            ");
            $stmt->execute(['date' => $date, 'formGroupId' => $formGroupId]);
        } else {
            $stmt = $db->prepare("
                SELECT 
                    p.gibbonPersonID as student_id,
                    CONCAT(p.preferredName, ' ', p.surname) as name,
                    alp.gibbonAttendanceCodeID as code,
                    ac.name as status,
                    ac.nameShort as status_short,
                    alp.comment,
                    alp.timestampTaken
                FROM gibbonPerson p
                JOIN gibbonCourseClassPerson ccp ON p.gibbonPersonID = ccp.gibbonPersonID
                LEFT JOIN gibbonAttendanceLogPerson alp ON p.gibbonPersonID = alp.gibbonPersonID 
                    AND alp.date = :date AND alp.gibbonCourseClassID = :classId
                LEFT JOIN gibbonAttendanceCode ac ON alp.gibbonAttendanceCodeID = ac.gibbonAttendanceCodeID
                WHERE ccp.gibbonCourseClassID = :classId
                AND ccp.role = 'Student'
                AND p.status = 'Full'
                ORDER BY p.surname, p.preferredName
            ");
            $stmt->execute(['date' => $date, 'classId' => $classId]);
        }

        $students = $stmt->fetchAll();

        // Get attendance codes for dropdown
        $codesStmt = $db->query("SELECT gibbonAttendanceCodeID as id, name, nameShort FROM gibbonAttendanceCode WHERE active = 'Y' ORDER BY sequenceNumber");
        $codes = $codesStmt->fetchAll();

        $response->getBody()->write(json_encode([
            'success' => true,
            'data' => [
                'date' => $date,
                'students' => $students,
                'codes' => $codes
            ]
        ]));

        return $response->withStatus(200);

    } catch (PDOException $e) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Database error: ' . $e->getMessage()
        ]));
        return $response->withStatus(500);
    }
})->add(RoleMiddleware::teacherOrAdmin())->add($authMiddleware);

