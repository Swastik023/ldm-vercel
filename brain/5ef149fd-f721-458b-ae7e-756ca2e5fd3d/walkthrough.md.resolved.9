<?php
/**
 * Role Middleware - Enforce Role-Based Access Control
 * 
 * Usage:
 *   ->add(RoleMiddleware::requireRole(['admin']))
 *   ->add(RoleMiddleware::requireRole(['admin', 'teacher']))
 */

use Psr\Http\Message\ResponseInterface as Response;
use Psr\Http\Message\ServerRequestInterface as Request;
use Psr\Http\Server\RequestHandlerInterface as RequestHandler;

class RoleMiddleware
{
    /**
     * Create middleware that requires specific roles
     * 
     * @param array $allowedRoles Array of allowed role names (e.g., ['admin', 'teacher'])
     * @return callable Middleware function
     */
    public static function requireRole(array $allowedRoles): callable
    {
        return function (Request $request, RequestHandler $handler) use ($allowedRoles): Response {
            $user = $request->getAttribute('user');

            // Check if user attribute exists (should be set by authMiddleware)
            if (!$user) {
                $response = new \Slim\Psr7\Response();
                $response->getBody()->write(json_encode([
                    'success' => false,
                    'error' => 'Unauthorized',
                    'message' => 'Authentication required'
                ]));
                return $response->withStatus(401)->withHeader('Content-Type', 'application/json');
            }

            // Get user role from JWT payload
            $userRole = $user->role ?? null;

            // Check if user's role is in allowed roles
            if (!$userRole || !in_array($userRole, $allowedRoles, true)) {
                $response = new \Slim\Psr7\Response();
                $response->getBody()->write(json_encode([
                    'success' => false,
                    'error' => 'Forbidden',
                    'message' => 'You do not have permission to access this resource',
                    'required_roles' => $allowedRoles,
                    'your_role' => $userRole
                ]));
                return $response->withStatus(403)->withHeader('Content-Type', 'application/json');
            }

            // Role is valid, proceed to next middleware/handler
            return $handler->handle($request);
        };
    }

    /**
     * Convenience method for admin-only routes
     */
    public static function adminOnly(): callable
    {
        return self::requireRole(['admin']);
    }

    /**
     * Convenience method for staff routes (admin + teacher + employee)
     */
    public static function staffOnly(): callable
    {
        return self::requireRole(['admin', 'teacher', 'employee']);
    }

    /**
     * Convenience method for teacher routes
     */
    public static function teacherOrAdmin(): callable
    {
        return self::requireRole(['admin', 'teacher']);
    }

    /**
     * Convenience method for student-only routes
     */
    public static function studentOnly(): callable
    {
        return self::requireRole(['student']);
    }

    /**
     * Convenience method for employee-only routes
     */
    public static function employeeOnly(): callable
    {
        return self::requireRole(['employee']);
    }

    /**
     * Any authenticated user
     */
    public static function anyAuthenticated(): callable
    {
        return self::requireRole(['admin', 'teacher', 'student', 'employee']);
    }

    /**
     * Middleware that allows access if user is admin OR is accessing their own resource
     * 
     * @param string $paramName The route parameter name containing the resource owner ID
     * @return callable
     */
    public static function requireOwnerOrAdmin(string $paramName = 'id'): callable
    {
        return function (Request $request, RequestHandler $handler) use ($paramName): Response {
            $user = $request->getAttribute('user');

            if (!$user) {
                $response = new \Slim\Psr7\Response();
                $response->getBody()->write(json_encode([
                    'success' => false,
                    'error' => 'Unauthorized',
                    'message' => 'Authentication required'
                ]));
                return $response->withStatus(401)->withHeader('Content-Type', 'application/json');
            }

            $userRole = $user->role ?? null;
            $userId = $user->user_id ?? null;

            // Admin can access anything
            if ($userRole === 'admin') {
                return $handler->handle($request);
            }

            // Check if user is accessing their own resource
            $routeArgs = $request->getAttribute('__route__')?->getArguments() ?? [];
            $resourceOwnerId = $routeArgs[$paramName] ?? null;

            if ($userId && $resourceOwnerId && $userId === $resourceOwnerId) {
                return $handler->handle($request);
            }

            $response = new \Slim\Psr7\Response();
            $response->getBody()->write(json_encode([
                'success' => false,
                'error' => 'Forbidden',
                'message' => 'You can only access your own resources'
            ]));
            return $response->withStatus(403)->withHeader('Content-Type', 'application/json');
        };
    }

    /**
     * Teacher accessing their own class resources
     * Verifies teacher is assigned to the class
     */
    public static function requireClassOwnership(): callable
    {
        return function (Request $request, RequestHandler $handler): Response {
            $user = $request->getAttribute('user');

            if (!$user) {
                $response = new \Slim\Psr7\Response();
                $response->getBody()->write(json_encode([
                    'success' => false,
                    'error' => 'Unauthorized'
                ]));
                return $response->withStatus(401)->withHeader('Content-Type', 'application/json');
            }

            // Admin bypasses class ownership check
            if (($user->role ?? null) === 'admin') {
                return $handler->handle($request);
            }

            // For teachers, class ownership is verified in the endpoint itself
            // This middleware just ensures the request proceeds for further validation
            return $handler->handle($request);
        };
    }
}
