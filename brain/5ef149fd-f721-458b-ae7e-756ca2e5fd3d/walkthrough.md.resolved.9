        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => InputValidator::getUsernameError()
        ]));
        return $response->withStatus(400);
    }

    // Validate password (basic check - don't leak password requirements to attackers)
    if (strlen($password) < 3 || strlen($password) > 255) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Invalid credentials'  // Generic message for security
        ]));
        return $response->withStatus(401);
    }

    // ===== AUTHENTICATION =====

    try {
        $db = getDB();

        // Query user
        $stmt = $db->prepare("
            SELECT gibbonPersonID, username, passwordStrong, gibbonRoleIDPrimary, 
                   preferredName, surname, email, status, canLogin
            FROM gibbonPerson 
            WHERE username = :username AND status = 'Full' AND canLogin = 'Y'
        ");
        $stmt->execute(['username' => $username]);
        $user = $stmt->fetch(PDO::FETCH_ASSOC);

        if (!$user || !password_verify($password, $user['passwordStrong'])) {
            $response->getBody()->write(json_encode([
                'success' => false,
                'error' => 'Invalid credentials'
            ]));
            return $response->withStatus(401);
        }

        // Get role information
        $stmt = $db->prepare("SELECT category, name FROM gibbonRole WHERE gibbonRoleID = :roleID");
        $stmt->execute(['roleID' => $user['gibbonRoleIDPrimary']]);
        $role = $stmt->fetch(PDO::FETCH_ASSOC);

        // Determine role for frontend
        $userRole = 'user';
        $roleID = $user['gibbonRoleIDPrimary'];

        if ($roleID === '001') {
            $userRole = 'admin';
        } elseif ($roleID === '002') {
            $userRole = 'teacher';
        } elseif ($roleID === '003') {
            $userRole = 'student';
        } elseif ($roleID === '006') {
            $userRole = 'employee';
        } else {
            // Fallback for others
            $userRole = strtolower($role['category'] ?? 'user');
        }

        // Generate JWT token
        $payload = [
            'user_id' => $user['gibbonPersonID'],
            'username' => $user['username'],
            'role' => $userRole,
            'role_name' => $role['name'] ?? 'Unknown',
            'role_id' => $user['gibbonRoleIDPrimary'],
            'exp' => time() + 3600  // 1 hour expiry
        ];

        $token = JWT::encode($payload, $jwtSecret, 'HS256');

