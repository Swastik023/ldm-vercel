$app->get('/admin/contact-messages', function (Request $request, Response $response) {
    $params = $request->getQueryParams();
    $status = $params['status'] ?? null;
    $page = max(1, intval($params['page'] ?? 1));
    $limit = min(100, max(1, intval($params['limit'] ?? 20)));
    $offset = ($page - 1) * $limit;

    try {
        $db = getDB();

        // Build query
        $where = $status ? "WHERE status = :status" : "";

        // Get total count
        $countStmt = $db->prepare("SELECT COUNT(*) as total FROM contact_messages $where");
        if ($status) {
            $countStmt->execute(['status' => $status]);
        } else {
            $countStmt->execute();
        }
        $total = $countStmt->fetch()['total'];

        // Get messages
        $stmt = $db->prepare("
            SELECT id, name, email, phone, subject, 
                   LEFT(message, 100) as message_preview,
                   status, created_at
            FROM contact_messages 
            $where
            ORDER BY created_at DESC 
            LIMIT :limit OFFSET :offset
        ");

        if ($status) {
            $stmt->bindValue(':status', $status);
        }
        $stmt->bindValue(':limit', $limit, PDO::PARAM_INT);
        $stmt->bindValue(':offset', $offset, PDO::PARAM_INT);
        $stmt->execute();

        $messages = $stmt->fetchAll();

        $response->getBody()->write(json_encode([
            'success' => true,
            'data' => [
                'messages' => $messages,
                'pagination' => [
                    'current_page' => $page,
                    'total_pages' => ceil($total / $limit),
                    'total_count' => $total,
                    'per_page' => $limit
                ]
            ]
        ]));

        return $response->withStatus(200);

    } catch (PDOException $e) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Failed to fetch messages'
        ]));
        return $response->withStatus(500);
    }
})->add(RoleMiddleware::adminOnly())->add($authMiddleware);

