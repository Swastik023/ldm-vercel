// PUT /admin/users/{id} - Update user
$app->put('/admin/users/{id}', function (Request $request, Response $response, $args) {
    $id = $args['id'];
    $data = $request->getParsedBody();
    $user = $request->getAttribute('user');
    $db = getDB();

    try {
        // Check user exists
        $checkStmt = $db->prepare("SELECT * FROM gibbonPerson WHERE gibbonPersonID = :id");
        $checkStmt->execute(['id' => $id]);
        $existingUser = $checkStmt->fetch(PDO::FETCH_ASSOC);

        if (!$existingUser) {
            return ApiResponse::notFound($response, 'User not found');
        }

        // Build update query dynamically
        $allowedFields = [
            'username',
            'email',
            'firstName',
            'preferredName',
            'surname',
            'title',
            'gender',
            'dob',
            'phone1',
            'phone1Type',
            'phone2',
            'address1',
            'address1District',
            'address1Country',
            'status',
            'canLogin',
            'studentID',
            'jobTitle'
        ];

        $updates = [];
        $params = ['id' => $id];

        foreach ($allowedFields as $field) {
            if (isset($data[$field])) {
                $updates[] = "$field = :$field";
                $params[$field] = $data[$field];
            }
        }

        // Handle full_name -> firstName/surname split
        if (isset($data['full_name']) && !isset($data['firstName'])) {
            $nameParts = explode(' ', trim($data['full_name']), 2);
            $updates[] = "firstName = :firstName";
            $updates[] = "preferredName = :preferredName";
            $updates[] = "surname = :surname";
            $params['firstName'] = $nameParts[0];
            $params['preferredName'] = $nameParts[0];
            $params['surname'] = $nameParts[1] ?? 'User';
        }

        // Handle role change
        if (isset($data['role'])) {
            $roleMap = [
                'student' => '003',
                'teacher' => '002',
                'admin' => '001',
                'employee' => '006'
            ];
            if (isset($roleMap[$data['role']])) {
                $updates[] = "gibbonRoleIDPrimary = :rolePrimary";
                $updates[] = "gibbonRoleIDAll = :roleAll";
                $params['rolePrimary'] = $roleMap[$data['role']];
                $params['roleAll'] = $roleMap[$data['role']];
            }
        }

        // Handle password change
        if (!empty($data['password'])) {
            $updates[] = "passwordStrong = :password";
            $params['password'] = password_hash($data['password'], PASSWORD_DEFAULT);
        }

        if (empty($updates)) {
            return ApiResponse::error($response, 'No valid fields to update', 400);
        }

        $sql = "UPDATE gibbonPerson SET " . implode(', ', $updates) . " WHERE gibbonPersonID = :id";
        $stmt = $db->prepare($sql);
        $stmt->execute($params);

        // Audit log
        AuditLogger::log('update', 'user', $id, $existingUser, $data, $user);

        return ApiResponse::success($response, ['message' => 'User updated successfully']);

    } catch (PDOException $e) {
        return ApiResponse::serverError($response, 'Database error: ' . $e->getMessage());
    }
})->add(RoleMiddleware::adminOnly())->add($authMiddleware);


