/**
 * GET /students
 * List all students (paginated)
 */
$app->get('/students', function (Request $request, Response $response) {
    $params = $request->getQueryParams();
    $page = $params['page'] ?? 1;
    $limit = $params['limit'] ?? 20;

    // ===== INPUT VALIDATION =====

    // Validate pagination parameters
    $validation = InputValidator::validatePagination($page, $limit, 100);

    if (!$validation['valid']) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Invalid pagination parameters'
        ]));
        return $response->withStatus(400);
    }

    // Use validated values
    $page = $validation['page'];
    $limit = $validation['limit'];
    $offset = ($page - 1) * $limit;

    // ===== CACHE CHECK =====

    $cacheKey = "students_list_page_{$page}_limit_{$limit}";
    $cached = Cache::get($cacheKey);

    if ($cached !== null) {
        $response->getBody()->write(json_encode([
            'success' => true,
            'data' => $cached['data'],
            'pagination' => $cached['pagination'],
            'cached' => true
        ]));
        return $response->withStatus(200);
    }

    // ===== DATABASE QUERY =====

    try {
        $db = getDB();

        $stmt = $db->prepare("
            SELECT 
                p.gibbonPersonID, 
                p.surname, 
                p.preferredName, 
                p.email,
                p.dateStart,
                yg.name as yearGroup,
                fg.name as formGroup
            FROM gibbonPerson p
            LEFT JOIN gibbonStudentEnrolment se ON p.gibbonPersonID = se.gibbonPersonID
            LEFT JOIN gibbonYearGroup yg ON se.gibbonYearGroupID = yg.gibbonYearGroupID
            LEFT JOIN gibbonFormGroup fg ON se.gibbonFormGroupID = fg.gibbonFormGroupID
            WHERE p.status = 'Full' AND (p.gibbonRoleIDPrimary IN (SELECT gibbonRoleID FROM gibbonRole WHERE category = 'Student'))
            ORDER BY p.surname, p.preferredName
            LIMIT :limit OFFSET :offset
        ");

        $stmt->bindValue(':limit', $limit, PDO::PARAM_INT);
        $stmt->bindValue(':offset', $offset, PDO::PARAM_INT);
        $stmt->execute();

        $students = $stmt->fetchAll(PDO::FETCH_ASSOC);

        // Get total count
        $total = $db->query("
            SELECT COUNT(*) FROM gibbonPerson p
            WHERE p.status = 'Full' AND (p.gibbonRoleIDPrimary IN (SELECT gibbonRoleID FROM gibbonRole WHERE category = 'Student'))
        ")->fetchColumn();

        $result = [
            'data' => $students,
            'pagination' => [
                'page' => $page,
                'limit' => $limit,
                'total' => (int) $total,
                'pages' => ceil($total / $limit)
            ]
        ];

        // Cache for 5 minutes (300 seconds)
        Cache::set($cacheKey, $result, 300);

        $response->getBody()->write(json_encode([
            'success' => true,
            'data' => $result['data'],
            'pagination' => $result['pagination'],
            'cached' => false
        ]));

        return $response->withStatus(200);

    } catch (PDOException $e) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Failed to fetch students'
        ]));
        return $response->withStatus(500);
    }
})->add($authMiddleware);

/**
 * GET /students/{id}
 * Get student details by ID
 */
$app->get('/students/{id}', function (Request $request, Response $response, array $args) {
    $studentId = $args['id'];

    // ===== INPUT VALIDATION =====

    // Validate student ID
    if (!InputValidator::validateId($studentId)) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => InputValidator::getIdError()
        ]));
        return $response->withStatus(400);
    }

    // ===== CACHE CHECK =====

    $cacheKey = "student_detail_{$studentId}";
    $cached = Cache::get($cacheKey);

    if ($cached !== null) {
        $response->getBody()->write(json_encode([
            'success' => true,
            'data' => $cached,
            'cached' => true
        ]));
        return $response->withStatus(200);
    }

    // ===== DATABASE QUERY =====

    try {
        $db = getDB();

        $stmt = $db->prepare("
            SELECT 
                p.*,
                yg.name as yearGroup,
                fg.name as formGroup,
                h.name as house
            FROM gibbonPerson p
            LEFT JOIN gibbonStudentEnrolment se ON p.gibbonPersonID = se.gibbonPersonID
            LEFT JOIN gibbonYearGroup yg ON se.gibbonYearGroupID = yg.gibbonYearGroupID
            LEFT JOIN gibbonFormGroup fg ON se.gibbonFormGroupID = fg.gibbonFormGroupID
            LEFT JOIN gibbonHouse h ON p.gibbonHouseID = h.gibbonHouseID
            WHERE p.gibbonPersonID = :id
        ");

        $stmt->execute(['id' => $studentId]);
        $student = $stmt->fetch(PDO::FETCH_ASSOC);

        if (!$student) {
            $response->getBody()->write(json_encode([
                'success' => false,
                'error' => 'Student not found'
            ]));
            return $response->withStatus(404);
        }

        // Cache for 10 minutes (600 seconds)
        Cache::set($cacheKey, $student, 600);

        $response->getBody()->write(json_encode([
            'success' => true,
            'data' => $student,
            'cached' => false
        ]));

        return $response->withStatus(200);

    } catch (PDOException $e) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Failed to fetch student'
        ]));
        return $response->withStatus(500);
    }
})->add($authMiddleware);

