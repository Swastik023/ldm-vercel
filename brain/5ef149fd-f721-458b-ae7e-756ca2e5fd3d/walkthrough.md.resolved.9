            LEFT JOIN gibbonCourse c ON cc.gibbonCourseID = c.gibbonCourseID
            WHERE alp.gibbonPersonID = :studentId
            AND alp.date BETWEEN :startDate AND :endDate
            ORDER BY alp.date DESC, alp.timestampTaken DESC
        ");
        $stmt->execute([
            'studentId' => $studentId,
            'startDate' => $startDate,
            'endDate' => $endDate
        ]);
        $attendance = $stmt->fetchAll(PDO::FETCH_ASSOC);
        
        // Calculate summary
        $summary = [
            'total_days' => count(array_unique(array_column($attendance, 'date'))),
            'present' => count(array_filter($attendance, fn($a) => strtolower($a['status']) === 'present')),
            'absent' => count(array_filter($attendance, fn($a) => strtolower($a['status']) === 'absent')),
            'late' => count(array_filter($attendance, fn($a) => strtolower($a['status']) === 'late'))
        ];
        
        $total = $summary['present'] + $summary['absent'] + $summary['late'];
        $summary['attendance_percentage'] = $total > 0 ? round(($summary['present'] / $total) * 100, 1) : 0;
        
        return ApiResponse::success($response, [
            'attendance' => $attendance,
            'summary' => $summary,
            'date_range' => ['start' => $startDate, 'end' => $endDate]
        ]);
        
    } catch (PDOException $e) {
        return ApiResponse::serverError($response, 'Database error: ' . $e->getMessage());
    }
})->add(RoleMiddleware::requireRole(['student', 'admin']))->add($authMiddleware);

