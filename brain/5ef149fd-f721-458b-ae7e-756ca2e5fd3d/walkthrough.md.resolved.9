/**
 * GET /timetable/{personId}
 * Get timetable for a person (student or teacher)
 * 
 * Query params:
 *   - date: Optional date (YYYY-MM-DD), defaults to today
 *   - week: Optional, if true returns full week schedule
 */
$app->get('/timetable/{personId}', function (Request $request, Response $response, array $args) {
    $personId = $args['personId'];
    $params = $request->getQueryParams();
    $date = $params['date'] ?? date('Y-m-d');
    $showWeek = isset($params['week']) && $params['week'] === 'true';

    // Validate person ID
    if (!InputValidator::validateId($personId)) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => InputValidator::getIdError()
        ]));
        return $response->withStatus(400);
    }

    try {
        $db = getDB();

        // Get person's role
        $roleStmt = $db->prepare("
            SELECT r.name as role
            FROM gibbonPerson p
            JOIN gibbonRole r ON p.gibbonRoleIDPrimary = r.gibbonRoleID
            WHERE p.gibbonPersonID = :id
        ");
        $roleStmt->execute(['id' => $personId]);
        $person = $roleStmt->fetch();

        if (!$person) {
            $response->getBody()->write(json_encode([
                'success' => false,
                'error' => 'Person not found'
            ]));
            return $response->withStatus(404);
        }

        $role = strtolower($person['role']);
        $isTeacher = ($role === 'teacher' || $role === 'staff');

        // Get the day of week (1 = Monday, 7 = Sunday)
        $dayOfWeek = date('N', strtotime($date));
        $dayNames = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
        $dayName = $dayNames[$dayOfWeek - 1];

        // Build the timetable query
        $sql = "
            SELECT 
                cc.gibbonCourseClassID as class_id,
                cc.name as class_name,
                c.name as course_name,
                c.nameShort as course_code,
                ttcr.timeStart as start_time,
                ttcr.timeEnd as end_time,
                s.name as room,
                ttd.name as day_name,
                ttcr.name as period_name
            FROM gibbonCourseClassPerson ccp
            JOIN gibbonCourseClass cc ON ccp.gibbonCourseClassID = cc.gibbonCourseClassID
            JOIN gibbonCourse c ON cc.gibbonCourseID = c.gibbonCourseID
            LEFT JOIN gibbonTTDayRowClass ttdrc ON cc.gibbonCourseClassID = ttdrc.gibbonCourseClassID
            LEFT JOIN gibbonTTColumnRow ttcr ON ttdrc.gibbonTTColumnRowID = ttcr.gibbonTTColumnRowID
            LEFT JOIN gibbonTTDay ttd ON ttdrc.gibbonTTDayID = ttd.gibbonTTDayID
            LEFT JOIN gibbonSpace s ON ttdrc.gibbonSpaceID = s.gibbonSpaceID
            WHERE ccp.gibbonPersonID = :personId
            AND ccp.role = :role
        ";

        $roleFilter = $isTeacher ? 'Teacher' : 'Student';
        $queryParams = ['personId' => $personId, 'role' => $roleFilter];

        if (!$showWeek) {
            $sql .= " AND (ttd.name = :dayName OR ttd.name IS NULL)";
            $queryParams['dayName'] = $dayName;
        }

        $sql .= " ORDER BY ttd.name, ttcr.timeStart";

        $stmt = $db->prepare($sql);
        $stmt->execute($queryParams);
        $classes = $stmt->fetchAll();

        // Group by day if showing full week
        $timetable = [];
        if ($showWeek) {
            foreach ($dayNames as $day) {
                $timetable[$day] = [];
            }
            foreach ($classes as $class) {
                $day = $class['day_name'] ?? 'Unscheduled';
                if (!isset($timetable[$day])) {
                    $timetable[$day] = [];
                }
                $timetable[$day][] = $class;
            }
        } else {
            $timetable = $classes;
        }

        $response->getBody()->write(json_encode([
            'success' => true,
            'data' => [
                'person_id' => $personId,
                'role' => $role,
                'date' => $date,
                'day_name' => $dayName,
                'is_week_view' => $showWeek,
                'timetable' => $timetable
            ]
        ]));

        return $response->withStatus(200);

    } catch (PDOException $e) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Database error: ' . $e->getMessage()
        ]));
        return $response->withStatus(500);
    }
})->add($authMiddleware);

