/**
 * GET /admin/audit-logs
 * Admin only - View audit logs
 */
$app->get('/admin/audit-logs', function (Request $request, Response $response) {
    $params = $request->getQueryParams();
    $page = max(1, intval($params['page'] ?? 1));
    $limit = min(100, max(1, intval($params['limit'] ?? 50)));
    $offset = ($page - 1) * $limit;

    // Filters
    $userId = $params['user_id'] ?? null;
    $action = $params['action'] ?? null;
    $entityType = $params['entity_type'] ?? null;
    $dateFrom = $params['date_from'] ?? null;
    $dateTo = $params['date_to'] ?? null;

    try {
        $db = getDB();

        // Build WHERE clause
        $where = [];
        $bindings = [];

        if ($userId) {
            $where[] = "user_id = :user_id";
            $bindings['user_id'] = $userId;
        }
        if ($action) {
            $where[] = "action = :action";
            $bindings['action'] = $action;
        }
        if ($entityType) {
            $where[] = "entity_type = :entity_type";
            $bindings['entity_type'] = $entityType;
        }
        if ($dateFrom) {
            $where[] = "created_at >= :date_from";
            $bindings['date_from'] = $dateFrom;
        }
        if ($dateTo) {
            $where[] = "created_at <= :date_to";
            $bindings['date_to'] = $dateTo . ' 23:59:59';
        }

        $whereClause = !empty($where) ? 'WHERE ' . implode(' AND ', $where) : '';

        // Get total count
        $stmt = $db->prepare("SELECT COUNT(*) as total FROM audit_logs $whereClause");
        $stmt->execute($bindings);
        $total = $stmt->fetch()['total'];

        // Get logs
        $stmt = $db->prepare("
            SELECT id, user_id, username, action, entity_type, entity_id,
                   old_values, new_values, ip_address, created_at
            FROM audit_logs
            $whereClause
            ORDER BY created_at DESC
            LIMIT :limit OFFSET :offset
        ");

        foreach ($bindings as $key => $value) {
            $stmt->bindValue(":$key", $value);
        }
        $stmt->bindValue(':limit', $limit, PDO::PARAM_INT);
        $stmt->bindValue(':offset', $offset, PDO::PARAM_INT);
        $stmt->execute();

        $logs = $stmt->fetchAll();

        $response->getBody()->write(json_encode([
            'success' => true,
            'data' => [
                'logs' => $logs,
                'pagination' => [
                    'current_page' => $page,
                    'total_pages' => ceil($total / $limit),
                    'total_count' => $total,
                    'per_page' => $limit
                ]
            ]
        ]));

        return $response->withStatus(200);

    } catch (PDOException $e) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Failed to fetch audit logs'
        ]));
        return $response->withStatus(500);
    }
})->add($authMiddleware)->add(PermissionManager::requirePermission('view_audit_logs'));

