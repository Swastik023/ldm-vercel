// JWT Authentication Middleware
$authMiddleware = function (Request $request, $handler) use ($jwtSecret) {
    $authHeader = $request->getHeaderLine('Authorization');

    if (!$authHeader || !preg_match('/Bearer\s+(.*)$/i', $authHeader, $matches)) {
        $response = new \Slim\Psr7\Response();
        $response->getBody()->write(json_encode(['error' => 'Unauthorized', 'message' => 'No token provided']));
        return $response->withStatus(401);
    }

    $token = $matches[1];

    try {
        $decoded = JWT::decode($token, new Key($jwtSecret, 'HS256'));
        $request = $request->withAttribute('user', $decoded);
        return $handler->handle($request);
    } catch (Exception $e) {
        $response = new \Slim\Psr7\Response();
        $response->getBody()->write(json_encode(['error' => 'Unauthorized', 'message' => 'Invalid token']));
        return $response->withStatus(401);
    }
};

