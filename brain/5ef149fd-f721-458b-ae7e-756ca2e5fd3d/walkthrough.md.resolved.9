    try {
        $db = getDB();

        $stmt = $db->prepare("
            INSERT INTO notices (title, content, category, priority, start_date, end_date, created_by)
            VALUES (:title, :content, :category, :priority, :start_date, :end_date, :created_by)
        ");

        $stmt->execute([
            'title' => Validator::sanitize($data['title']),
            'content' => Validator::sanitize($data['content']),
            'category' => $data['category'] ?? 'general',
            'priority' => $data['priority'] ?? 'normal',
            'start_date' => $data['start_date'] ?? null,
            'end_date' => $data['end_date'] ?? null,
            'created_by' => $user->user_id
        ]);

        $response->getBody()->write(json_encode([
            'success' => true,
            'message' => 'Notice created successfully',
            'id' => $db->lastInsertId()
        ]));

