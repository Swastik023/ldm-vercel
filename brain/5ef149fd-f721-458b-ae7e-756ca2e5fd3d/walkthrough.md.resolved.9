/**
 * POST /admin/gallery/bulk-delete
 * Admin only - Bulk delete images
 */
$app->post('/admin/gallery/bulk-delete', function (Request $request, Response $response) {
    $data = $request->getParsedBody();
    $ids = $data['ids'] ?? [];

    if (empty($ids)) {
        return $response->withStatus(400);
    }

    try {
        $db = getDB();
        $uploader = new ImageUploader();
        $count = 0;

        foreach ($ids as $id) {
            // Get image info
            $stmt = $db->prepare("SELECT image_url FROM gallery WHERE id = :id");
            $stmt->execute(['id' => $id]);
            $image = $stmt->fetch();

            if ($image) {
                // Delete files
                $filename = basename($image['image_url']);
                $uploader->delete($filename);

                // Delete DB record
                $stmt = $db->prepare("DELETE FROM gallery WHERE id = :id");
                $stmt->execute(['id' => $id]);
                $count++;
            }
        }

        $response->getBody()->write(json_encode([
            'success' => true,
            'message' => "Deleted $count items",
            'count' => $count
        ]));

        return $response->withStatus(200);

    } catch (Exception $e) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Failed to delete images'
        ]));
        return $response->withStatus(500);
    }
})->add(RoleMiddleware::adminOnly())->add($authMiddleware);

