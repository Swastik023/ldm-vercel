/**
 * POST /teacher/attendance/mark - Mark attendance for a class
 */
$app->post('/teacher/attendance/mark', function (Request $request, Response $response) {
    $data = $request->getParsedBody();
    $user = $request->getAttribute('user');
    $teacherId = $user->user_id;
    $db = getDB();

    // Validate required fields
    if (empty($data['class_id']) || empty($data['date']) || empty($data['attendance'])) {
        return ApiResponse::validationError($response, [
            'class_id' => 'Class ID is required',
            'date' => 'Date is required',
            'attendance' => 'Attendance records are required'
        ]);
    }

    $classId = $data['class_id'];
    $date = $data['date'];
    $attendanceRecords = $data['attendance']; // Array of {student_id, type, comment}

    try {
        // Verify teacher owns this class (unless admin)
        if ($user->role !== 'admin') {
            $checkStmt = $db->prepare("
                SELECT gibbonCourseClassPersonID FROM gibbonCourseClassPerson 
                WHERE gibbonCourseClassID = :classId AND gibbonPersonID = :teacherId AND role IN ('Teacher', 'Assistant')
            ");
            $checkStmt->execute(['classId' => $classId, 'teacherId' => $teacherId]);

            if (!$checkStmt->fetch()) {
                return ApiResponse::forbidden($response, 'You are not assigned to this class');
            }
        }

        // Get attendance types from gibbonAttendanceCode
        $typeStmt = $db->query("SELECT gibbonAttendanceCodeID, name, direction FROM gibbonAttendanceCode WHERE active = 'Y'");
        $attendanceTypes = $typeStmt->fetchAll(PDO::FETCH_KEY_PAIR);

        $db->beginTransaction();

        $insertCount = 0;
        $updateCount = 0;

        foreach ($attendanceRecords as $record) {
            $studentId = $record['student_id'];
            $type = strtolower($record['type'] ?? 'present'); // present, absent, late
            $comment = $record['comment'] ?? '';

            // Map simple types to Gibbon attendance codes
            $direction = 'In';
            if ($type === 'absent') {
                $direction = 'Out';
            }

            // Check if attendance already exists for this student/class/date
            $existsStmt = $db->prepare("
                SELECT gibbonAttendanceLogPersonID FROM gibbonAttendanceLogPerson 
                WHERE gibbonPersonID = :studentId 
                AND gibbonCourseClassID = :classId 
                AND date = :date
            ");
            $existsStmt->execute(['studentId' => $studentId, 'classId' => $classId, 'date' => $date]);
            $existing = $existsStmt->fetch();

            if ($existing) {
                // Update existing
                $updateStmt = $db->prepare("
                    UPDATE gibbonAttendanceLogPerson 
                    SET type = :type, direction = :direction, comment = :comment, 
                        gibbonPersonIDTaker = :takerId, timestampTaken = NOW()
                    WHERE gibbonAttendanceLogPersonID = :id
                ");
                $updateStmt->execute([
                    'type' => ucfirst($type),
                    'direction' => $direction,
                    'comment' => $comment,
                    'takerId' => $teacherId,
                    'id' => $existing['gibbonAttendanceLogPersonID']
                ]);
                $updateCount++;
            } else {
                // Insert new
                $insertStmt = $db->prepare("
                    INSERT INTO gibbonAttendanceLogPerson 
                    (gibbonPersonID, gibbonCourseClassID, date, type, direction, comment, gibbonPersonIDTaker, timestampTaken, context)
                    VALUES (:studentId, :classId, :date, :type, :direction, :comment, :takerId, NOW(), 'Class')
                ");
                $insertStmt->execute([
                    'studentId' => $studentId,
                    'classId' => $classId,
                    'date' => $date,
                    'type' => ucfirst($type),
                    'direction' => $direction,
                    'comment' => $comment,
                    'takerId' => $teacherId
                ]);
                $insertCount++;
            }
        }

        $db->commit();

        AuditLogger::log('mark_attendance', 'class', $classId, null, [
            'date' => $date,
            'records_count' => count($attendanceRecords)
        ], $user);

        return ApiResponse::success($response, [
            'message' => 'Attendance marked successfully',
            'inserted' => $insertCount,
            'updated' => $updateCount
        ]);

    } catch (PDOException $e) {
        if ($db->inTransaction()) {
            $db->rollBack();
        }
        return ApiResponse::serverError($response, 'Database error: ' . $e->getMessage());
    }
})->add(RoleMiddleware::teacherOrAdmin())->add($authMiddleware);

/**
 * GET /teacher/attendance/{classId} - Get attendance for a class
 */
$app->get('/teacher/attendance/{classId}', function (Request $request, Response $response, $args) {
    $classId = $args['classId'];
    $params = $request->getQueryParams();
    $date = $params['date'] ?? date('Y-m-d');
    $user = $request->getAttribute('user');
    $teacherId = $user->user_id;
    $db = getDB();

    try {
        // Verify teacher owns this class (unless admin)
        if ($user->role !== 'admin') {
            $checkStmt = $db->prepare("
                SELECT gibbonCourseClassPersonID FROM gibbonCourseClassPerson 
                WHERE gibbonCourseClassID = :classId AND gibbonPersonID = :teacherId AND role IN ('Teacher', 'Assistant')
            ");
            $checkStmt->execute(['classId' => $classId, 'teacherId' => $teacherId]);

            if (!$checkStmt->fetch()) {
                return ApiResponse::forbidden($response, 'You are not assigned to this class');
            }
        }

        // Get all students in class with their attendance for the date
        $stmt = $db->prepare("
            SELECT 
                p.gibbonPersonID as student_id,
                CONCAT(p.preferredName, ' ', p.surname) as name,
                p.studentID,
                alp.type as attendance_type,
                alp.direction,
                alp.comment,
                alp.timestampTaken as marked_at,
                CONCAT(taker.preferredName, ' ', taker.surname) as marked_by
            FROM gibbonCourseClassPerson ccp
            JOIN gibbonPerson p ON ccp.gibbonPersonID = p.gibbonPersonID
            LEFT JOIN gibbonAttendanceLogPerson alp ON p.gibbonPersonID = alp.gibbonPersonID 
                AND alp.gibbonCourseClassID = :classId 
                AND alp.date = :date
            LEFT JOIN gibbonPerson taker ON alp.gibbonPersonIDTaker = taker.gibbonPersonID
            WHERE ccp.gibbonCourseClassID = :classId2
            AND ccp.role = 'Student'
            ORDER BY p.surname, p.preferredName
        ");
        $stmt->execute(['classId' => $classId, 'date' => $date, 'classId2' => $classId]);
        $attendance = $stmt->fetchAll(PDO::FETCH_ASSOC);

        // Get class info
        $classStmt = $db->prepare("
            SELECT cc.name as class_name, c.name as course_name 
            FROM gibbonCourseClass cc
            JOIN gibbonCourse c ON cc.gibbonCourseID = c.gibbonCourseID
            WHERE cc.gibbonCourseClassID = :classId
        ");
        $classStmt->execute(['classId' => $classId]);
        $classInfo = $classStmt->fetch(PDO::FETCH_ASSOC);

        // Calculate summary
        $summary = [
            'total' => count($attendance),
            'present' => count(array_filter($attendance, fn($a) => strtolower($a['attendance_type'] ?? '') === 'present')),
            'absent' => count(array_filter($attendance, fn($a) => strtolower($a['attendance_type'] ?? '') === 'absent')),
            'late' => count(array_filter($attendance, fn($a) => strtolower($a['attendance_type'] ?? '') === 'late')),
            'not_marked' => count(array_filter($attendance, fn($a) => empty($a['attendance_type'])))
        ];

        return ApiResponse::success($response, [
            'class' => $classInfo,
            'date' => $date,
            'attendance' => $attendance,
            'summary' => $summary
        ]);

    } catch (PDOException $e) {
        return ApiResponse::serverError($response, 'Database error: ' . $e->getMessage());
    }
})->add(RoleMiddleware::teacherOrAdmin())->add($authMiddleware);

/**
 * GET /teacher/schedule - Get teacher's schedule/timetable
 */
$app->get('/teacher/schedule', function (Request $request, Response $response) {
    $user = $request->getAttribute('user');
    $teacherId = $user->user_id;
    $db = getDB();

    try {
        // Get classes with their schedule info
        $stmt = $db->prepare("
            SELECT 
                cc.gibbonCourseClassID as class_id,
                cc.name as class_name,
                c.name as course_name,
                ttdr.timeStart,
                ttdr.timeEnd,
                ttd.name as day_name,
                s.name as room_name
            FROM gibbonCourseClassPerson ccp
            JOIN gibbonCourseClass cc ON ccp.gibbonCourseClassID = cc.gibbonCourseClassID
            JOIN gibbonCourse c ON cc.gibbonCourseID = c.gibbonCourseID
            LEFT JOIN gibbonTTDayRowClass ttdrc ON cc.gibbonCourseClassID = ttdrc.gibbonCourseClassID
            LEFT JOIN gibbonTTDayRow ttdr ON ttdrc.gibbonTTDayRowID = ttdr.gibbonTTDayRowID
            LEFT JOIN gibbonTTDay ttd ON ttdr.gibbonTTDayID = ttd.gibbonTTDayID
            LEFT JOIN gibbonSpace s ON ttdrc.gibbonSpaceID = s.gibbonSpaceID
            WHERE ccp.gibbonPersonID = :teacherId
            AND ccp.role IN ('Teacher', 'Assistant')
            ORDER BY ttd.name, ttdr.timeStart
        ");
        $stmt->execute(['teacherId' => $teacherId]);
        $schedule = $stmt->fetchAll(PDO::FETCH_ASSOC);

        // Group by day
        $byDay = [];
        foreach ($schedule as $slot) {
            $day = $slot['day_name'] ?? 'Unscheduled';
            if (!isset($byDay[$day])) {
                $byDay[$day] = [];
            }
            $byDay[$day][] = $slot;
        }

        return ApiResponse::success($response, [
            'schedule' => $schedule,
            'by_day' => $byDay
        ]);

    } catch (PDOException $e) {
        return ApiResponse::serverError($response, 'Database error: ' . $e->getMessage());
    }
})->add(RoleMiddleware::teacherOrAdmin())->add($authMiddleware);


