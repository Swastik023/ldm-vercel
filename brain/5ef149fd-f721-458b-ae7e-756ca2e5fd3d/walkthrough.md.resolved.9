        return $response->withStatus(400);
    }

    try {
        $db = getDB();

        // Build dynamic update query
        $updates = [];
        $params = ['id' => $id];

        foreach (['title', 'description', 'category', 'display_order'] as $field) {
            if (isset($data[$field])) {
                $updates[] = "$field = :$field";
                $params[$field] = in_array($field, ['title', 'description'])
                    ? Validator::sanitize($data[$field])
                    : $data[$field];
            }
        }

        if (isset($data['is_active'])) {
            $updates[] = "is_active = :is_active";
            $params['is_active'] = $data['is_active'] ? 1 : 0;
        }

        if (empty($updates)) {
            $response->getBody()->write(json_encode([
                'success' => false,
                'error' => 'No fields to update'
            ]));
            return $response->withStatus(400);
        }

        $sql = "UPDATE gallery SET " . implode(', ', $updates) . " WHERE id = :id";
        $stmt = $db->prepare($sql);
        $stmt->execute($params);

        if ($stmt->rowCount() === 0) {
            $response->getBody()->write(json_encode([
                'success' => false,
                'error' => 'Image not found'
            ]));
            return $response->withStatus(404);
        }

        $response->getBody()->write(json_encode([
            'success' => true,
            'message' => 'Image updated successfully'
        ]));

        return $response->withStatus(200);

    } catch (PDOException $e) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Failed to update image'
        ]));
        return $response->withStatus(500);
    }
})->add(RoleMiddleware::adminOnly())->add($authMiddleware);

