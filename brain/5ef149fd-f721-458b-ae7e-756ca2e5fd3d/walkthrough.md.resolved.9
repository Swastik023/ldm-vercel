/**
 * PUT /admin/notices/{id}
 * Admin only - Update notice
 */
$app->put('/admin/notices/{id}', function (Request $request, Response $response, array $args) {
    $id = intval($args['id']);
    $data = json_decode($request->getBody()->getContents(), true);

    // Validate input
    $errors = Validator::validate($data, [
        'title' => ['min' => 5, 'max' => 200],
        'content' => ['min' => 10, 'max' => 10000],
        'category' => ['enum' => ['general', 'academic', 'exam', 'event', 'urgent']],
        'priority' => ['enum' => ['low', 'normal', 'high']],
        'start_date' => ['date' => true],
        'end_date' => ['date' => true]
    ]);

    if ($errors) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'errors' => $errors
        ]));
        return $response->withStatus(400);
    }

    try {
        $db = getDB();

        // Build dynamic update query
        $updates = [];
        $params = ['id' => $id];

        foreach (['title', 'content', 'category', 'priority', 'start_date', 'end_date'] as $field) {
            if (isset($data[$field])) {
                $updates[] = "$field = :$field";
                $params[$field] = in_array($field, ['title', 'content'])
                    ? Validator::sanitize($data[$field])
                    : $data[$field];
            }
        }

        if (isset($data['is_active'])) {
            $updates[] = "is_active = :is_active";
            $params['is_active'] = $data['is_active'] ? 1 : 0;
        }

        if (empty($updates)) {
            $response->getBody()->write(json_encode([
                'success' => false,
                'error' => 'No fields to update'
            ]));
            return $response->withStatus(400);
        }

        $sql = "UPDATE notices SET " . implode(', ', $updates) . " WHERE id = :id";
        $stmt = $db->prepare($sql);
        $stmt->execute($params);

        if ($stmt->rowCount() === 0) {
            $response->getBody()->write(json_encode([
                'success' => false,
                'error' => 'Notice not found'
            ]));
            return $response->withStatus(404);
        }

        $response->getBody()->write(json_encode([
            'success' => true,
            'message' => 'Notice updated successfully'
        ]));

        return $response->withStatus(200);

    } catch (PDOException $e) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Failed to update notice'
        ]));
        return $response->withStatus(500);
    }
})->add($authMiddleware);

