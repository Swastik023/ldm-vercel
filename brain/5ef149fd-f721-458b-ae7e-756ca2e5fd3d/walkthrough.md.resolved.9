 */
$app->get('/admin/stats', function (Request $request, Response $response) {
    try {
        $db = getDB();

        // Get student counts
        $studentStats = $db->query("
            SELECT 
                COUNT(*) as total,
                SUM(CASE WHEN status = 'Full' THEN 1 ELSE 0 END) as active
            FROM gibbonPerson 
            WHERE gibbonRoleIDPrimary = '003'  -- Student role
        ")->fetch();

        // Get staff counts  
        $staffStats = $db->query("
            SELECT 
                COUNT(*) as total,
                SUM(CASE WHEN category = 'Staff' THEN 1 ELSE 0 END) as teachers
            FROM gibbonPerson p
            JOIN gibbonRole r ON p.gibbonRoleIDPrimary = r.gibbonRoleID
            WHERE r.category IN ('Staff', 'Administrator')
        ")->fetch();

        // Get notices counts
        $noticeStats = $db->query("
            SELECT 
                COUNT(*) as total,
                SUM(CASE WHEN is_active = 1 AND 
                    (start_date IS NULL OR start_date <= CURDATE()) AND
                    (end_date IS NULL OR end_date >= CURDATE()) THEN 1 ELSE 0 END) as active
            FROM notices
        ")->fetch();

        // Get contact messages count
        $contactStats = $db->query("
            SELECT 
                COUNT(*) as total,
                SUM(CASE WHEN status = 'new' THEN 1 ELSE 0 END) as new
            FROM contact_messages
        ")->fetch();

        // Get gallery counts
        $galleryStats = $db->query("
            SELECT 
                COUNT(*) as total,
                SUM(CASE WHEN is_active = 1 THEN 1 ELSE 0 END) as active
            FROM gallery
        ")->fetch();

        $response->getBody()->write(json_encode([
            'success' => true,
            'data' => [
                'students' => [
                    'total' => intval($studentStats['total'] ?? 0),
                    'active' => intval($studentStats['active'] ?? 0)
                ],
                'staff' => [
                    'total' => intval($staffStats['total'] ?? 0),
                    'teachers' => intval($staffStats['teachers'] ?? 0)
                ],
                'notices' => [
                    'total' => intval($noticeStats['total'] ?? 0),
                    'active' => intval($noticeStats['active'] ?? 0)
                ],
                'contact_messages' => [
                    'total' => intval($contactStats['total'] ?? 0),
                    'new' => intval($contactStats['new'] ?? 0)
                ],
                'gallery' => [
                    'total' => intval($galleryStats['total'] ?? 0),
                    'active' => intval($galleryStats['active'] ?? 0)
                ]
            ]
        ]));

        return $response->withStatus(200);

    } catch (PDOException $e) {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Failed to fetch statistics'
        ]));
        return $response->withStatus(500);
