DB_USER=u542293952_ldm
DB_PASS=your_password_here
SESSION_KEY=your_32_char_random_key
```

Update `config.php` to use:
```php
<?php
// Load environment (if using phpdotenv)
require __DIR__.'/vendor/autoload.php';
$dotenv = Dotenv\Dotenv::createImmutable(__DIR__);
$dotenv->load();

return [
    'databaseServer' => $_ENV['DB_HOST'],
    'databaseName' => $_ENV['DB_NAME'],
    'databaseUsername' => $_ENV['DB_USER'],
    'databasePassword' => $_ENV['DB_PASS'],
    // ... rest of config
];
```

