# Automated backup script (setup in cron)
#!/bin/bash
DATE=$(date +%Y%m%d_%H%M%S)
mysqldump -u u542293952_ldm -p \
  u542293952_productionldm > \
  /home/u542293952/private/backups/gibbon_$DATE.sql

# Keep only last 30 days
find /home/u542293952/private/backups/ -name "gibbon_*.sql" -mtime +30 -delete
```

#### Cron Setup (via Hostinger cPanel)
```
# Daily backup at 2 AM
0 2 * * * /home/u542293952/scripts/backup.sh

# Clear old sessions daily
0 3 * * * php /home/u542293952/public_html/backend/cli/session_cleanup.php
```

