## Security Implementation

### Admin Role Middleware

```php
function requireAdmin(Request $request, Response $response, callable $next) {
    $user = $request->getAttribute('user');
    
    if (!$user || $user->role !== 'Staff') {
        $response->getBody()->write(json_encode([
            'success' => false,
            'error' => 'Admin access required'
        ]));
        return $response->withStatus(403);
    }
    
    return $next($request, $response);
}
```

### Input Validation Helper

```php
class Validator {
    public static function validate($data, $rules) {
        $errors = [];
        
        foreach ($rules as $field => $rule) {
            // Required check
            if (isset($rule['required']) && empty($data[$field])) {
                $errors[$field] = "{$field} is required";
                continue;
            }
            
            // Length validation
            if (isset($rule['min']) || isset($rule['max'])) {
                $len = strlen($data[$field]);
                if (isset($rule['min']) && $len < $rule['min']) {
                    $errors[$field] = "{$field} must be at least {$rule['min']} characters";
                }
                if (isset($rule['max']) && $len > $rule['max'])) {
                    $errors[$field] = "{$field} must not exceed {$rule['max']} characters";
                }
            }
            
            // Email validation
            if (isset($rule['email']) && !filter_var($data[$field], FILTER_VALIDATE_EMAIL)) {
                $errors[$field] = "{$field} must be a valid email";
            }
        }
        
        return empty($errors) ? null : $errors;
    }
}
```

### Rate Limiting

```php
class RateLimiter {
    private $cacheDir = '/tmp/rate_limit/';
    
    public function check($key, $maxAttempts = 3, $decayMinutes = 10) {
        $file = $this->cacheDir . md5($key);
        $data = file_exists($file) ? json_decode(file_get_contents($file), true) : null;
        
        if ($data && $data['expires'] > time()) {
            if ($data['attempts'] >= $maxAttempts) {
                return false; // Rate limit exceeded
            }
            $data['attempts']++;
        } else {
            $data = [
                'attempts' => 1,
                'expires' => time() + ($decayMinutes * 60)
            ];
        }
        
        file_put_contents($file, json_encode($data));
        return true;
    }
}
```

