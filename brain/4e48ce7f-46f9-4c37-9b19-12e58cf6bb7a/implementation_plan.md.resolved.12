### 4. JSON Schema Validation

---

#### [NEW] `src/lib/testSchemaValidator.ts`

Validates uploaded JSON files strictly:

**`questions.json` required shape:**
```json
{
  "testMeta": {
    "title": "string",
    "description": "string",
    "durationMinutes": 60,
    "totalMarks": 100,
    "batch": "batchId",
    "subject": "subjectId",
    "negativeMarking": 0.25,
    "shuffleQuestions": false,
    "shuffleOptions": false,
    "resultMode": "instant"
  },
  "sections": [{ "sectionId": "S1", "title": "Section A", "instructions": "" }],
  "questions": [{
    "questionId": "Q1",
    "sectionId": "S1",
    "type": "mcq",
    "questionText": "...",
    "marks": 2,
    "options": [
      { "label": "A", "text": "..." },
      { "label": "B", "text": "..." },
      { "label": "C", "text": "..." },
      { "label": "D", "text": "..." }
    ]
  }]
}
```

**`answers.json` required shape:**
```json
{
  "testTitle": "same as questions.json testMeta.title",
  "answers": [{
    "questionId": "Q1",
    "correctAnswer": "B",
    "reason": "Because..."
  }]
}
```

